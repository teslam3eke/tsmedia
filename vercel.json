{
  "rewrites": [
    {
      "source": "/build-id.txt",
      "destination": "/api/git-sha"
    }
  ],
  "crons": [
    {
      "path": "/api/cron-discover-rollover-push",
      "schedule": "0 14 * * *"
    }
  ],
  "functions": {
    "api/cron-discover-rollover-push.ts": {
      "maxDuration": 120
    }
  },
  "headers": [
    {
      "source": "/api/git-sha",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/manifest+json; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/build-id.txt",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
