# tsMedia 環境變數範例（複製為 .env.local，勿提交）

# ── Supabase ─────────────────────────────────────────────
# 前端 build 用 VITE_*；金流 API（ecpay-create-order / notify）還需要 SERVICE_ROLE
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# 若 Vercel 只設了下面兩個，建單 API 會 fallback；但 SERVICE_ROLE 必填
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 正式站網址（註冊信 redirect、綠界 ReturnURL 基底）
VITE_SITE_URL=https://tsmedia.tw

# Meta 廣告追蹤（事件管理工具 Pixel ID；未設則不載入）
VITE_META_PIXEL_ID=1053632237201148

# ── 綠界 ECPay（B 方案：單次付清，手動續費）──────────────
# 測試後台：https://vendor-stage.ecpay.com.tw/ → ECPAY_SANDBOX=true
# 正式後台：https://vendor.ecpay.com.tw/       → ECPAY_SANDBOX=false
# 後台須設定 PaymentInfoURL / OrderResultURL（見 api/_utils/ecpayConfig.ts）
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=
ECPAY_SANDBOX=true
ECPAY_SITE_URL=https://tsmedia.tw
# 付款完成前景導回（預設 tsmedia.tw 時自動用 www；全站改 apex 後可刪除）
# ECPAY_RETURN_SITE_URL=https://www.tsmedia.tw

# ── TapPay（舊整合；若已改用綠界可留空）──────────────────
VITE_TAPPAY_APP_ID=
VITE_TAPPAY_APP_KEY=
VITE_TAPPAY_SERVER_TYPE=sandbox
TAPPAY_PARTNER_KEY=
TAPPAY_MERCHANT_ID=
TAPPAY_SANDBOX=true
