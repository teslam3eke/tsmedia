# tsMedia 環境變數範例（複製為 .env.local，勿提交）

# ── Supabase ─────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 正式站網址（註冊信 redirect、藍新 ReturnURL 基底）
VITE_SITE_URL=https://www.tsmedia.tw

# ── 藍新金流 NewebPay（B 方案：單次付清，手動續費）────────
# 測試後台：https://cwww.newebpay.com/  → NEWEBPAY_SANDBOX=true
# 正式後台：https://www.newebpay.com/    → NEWEBPAY_SANDBOX=false
NEWEBPAY_MERCHANT_ID=
NEWEBPAY_HASH_KEY=
NEWEBPAY_HASH_IV=
NEWEBPAY_SANDBOX=true
NEWEBPAY_SITE_URL=https://www.tsmedia.tw

# ── TapPay（舊整合；若已改用藍新可留空）──────────────────
VITE_TAPPAY_APP_ID=
VITE_TAPPAY_APP_KEY=
VITE_TAPPAY_SERVER_TYPE=sandbox
TAPPAY_PARTNER_KEY=
TAPPAY_MERCHANT_ID=
TAPPAY_SANDBOX=true
