# tsMedia 環境變數範例（複製為 .env.local，勿提交）

# ── Supabase ─────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 正式站網址（註冊信 redirect、綠界 ReturnURL 基底）
VITE_SITE_URL=https://www.tsmedia.tw

# ── 綠界 ECPay（B 方案：單次付清，手動續費）──────────────
# 測試後台：https://vendor-stage.ecpay.com.tw/ → ECPAY_SANDBOX=true
# 正式後台：https://vendor.ecpay.com.tw/       → ECPAY_SANDBOX=false
# 後台須設定 PaymentInfoURL / OrderResultURL（見 api/_utils/ecpayConfig.ts）
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=
ECPAY_SANDBOX=true
ECPAY_SITE_URL=https://www.tsmedia.tw

# ── TapPay（舊整合；若已改用綠界可留空）──────────────────
VITE_TAPPAY_APP_ID=
VITE_TAPPAY_APP_KEY=
VITE_TAPPAY_SERVER_TYPE=sandbox
TAPPAY_PARTNER_KEY=
TAPPAY_MERCHANT_ID=
TAPPAY_SANDBOX=true
